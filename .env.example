META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id
FACEBOOK_PAGE_ID=your_facebook_page_id

# Paste your short-lived User Access Token from the Graph API Explorer here.
# On first run, the app will exchange it for a non-expiring Page Token automatically.
ACCESS_TOKEN=your_access_token_from_graph_api_explorer

# Optional: Cloudinary credentials for media uploads
# Sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Turso database (cloud SQLite)
# Create one at https://turso.tech
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# OpenAI API key (required for auto-generated climate infographics)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Perplexity API key (optional, used as supplementary research for investigative archetypes)
# Get one at https://docs.perplexity.ai
PERPLEXITY_API_KEY=your_perplexity_api_key

# Tavily API key (primary research engine for authoritative climate data)
# Get one at https://tavily.com — free tier includes 1000 searches/month
TAVILY_API_KEY=your_tavily_api_key

# Telegram Bot (for post approval before publishing)
# 1. Message @BotFather on Telegram, send /newbot, follow instructions
# 2. Copy the bot token here
# 3. Message your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# For serverless/cloud: set webhook URL so Telegram sends button clicks to your server
# Example: https://your-domain.com/api/telegram/webhook
# Leave empty for local development (uses polling instead)
TELEGRAM_WEBHOOK_URL=

# Auto-posting schedule (24-hour format, local timezone)
PIPELINE_MORNING_HOUR=9
PIPELINE_EVENING_HOUR=18
PIPELINE_POSTING_HOURS=8,12,16,20
PIPELINE_TIMEZONE=

PORT=3000
